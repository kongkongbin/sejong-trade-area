# 서버 포트
PORT=4000

# MySQL 접속 정보
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sejong_trade_area

# JWT
JWT_SECRET=change_this_to_a_random_long_string
JWT_EXPIRES_IN=12h

# 프론트엔드 주소 (CORS 허용용)
CLIENT_ORIGIN=http://localhost:5173

# 공공데이터포털 서비스키 (소상공인 상가정보 등)
DATA_GO_KR_SERVICE_KEY=

# Naver Maps (서버에서 geocoding 등 호출 시 사용)
NAVER_MAPS_CLIENT_ID=
NAVER_MAPS_CLIENT_SECRET=
